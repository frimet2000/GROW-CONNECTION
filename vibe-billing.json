{
  "project": "GROW-CONNECTION",
  "client": "VIBE CODING",
  "platform": "BASE44",
  "billing_gateway": "GROW (Meshulam)",
  "settings": {
    "api_version": "1.0.0",
    "required_env_vars": [
      {
        "key": "GROW_PAGE_CODE",
        "label": "קוד דף (pageCode)",
        "description": "קוד הדף הייחודי שהונפק בממשק Grow"
      },
      {
        "key": "GROW_USER_ID",
        "label": "מזהה משתמש (userId)",
        "description": "מזהה המשתמש (Merchant ID) במערכת Grow"
      },
      {
        "key": "GROW_API_KEY",
        "label": "מפתח API (במידה ונדרש)",
        "description": "מפתח ה-API לביצוע פעולות שרת-לשרת"
      }
    ],
    "endpoints": {
      "create_payment": {
        "function_name": "createGrowPaymentLink",
        "method": "POST",
        "mapping": {
          "orderId": "entity.id",
          "totalAmount": "entity.total",
          "customerEmail": "user.email",
          "customerName": "user.full_name",
          "customerPhone": "user.phone"
        }
      }
    }
  }
}
