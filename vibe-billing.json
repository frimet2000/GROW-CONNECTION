{
  "project": "GROW-CONNECTION",
  "client": "VIBE CODING",
  "platform": "BASE44",
  "billing_gateway": "GROW (Meshulam)",
  "settings": {
    "api_version": "1.0.0",
    "required_env_vars": [
      {
        "key": "GROW_PAGE_CODE",
        "label": "pageCode",
        "description": "התקבל ממערכת משולם"
      },
      {
        "key": "GROW_USER_ID",
        "label": "userId",
        "description": "מזהה המשתמש במערכת משולם"
      }
    ],
    "endpoints": {
      "create_payment": {
        "url": "https://api.meshulam.co.il/api/light/createPaymentPage",
        "method": "POST",
        "payload": {
          "userId": "env.GROW_USER_ID",
          "pageCode": "env.GROW_PAGE_CODE",
          "sum": "amount",
          "description": "description",
          "fullName": "customerName",
          "phone": "customerPhone",
          "successUrl": "successUrl",
          "cancelUrl": "cancelUrl"
        }
      },
      "check_status": {
        "url": "https://api.meshulam.co.il/api/light/server/1.0/getPaymentProcessInfo",
        "method": "POST",
        "auth": "FormData (userId, pageCode, processId)"
      }
    }
  }
}
